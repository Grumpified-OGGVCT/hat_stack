# Dockerfile.pipeline — Ephemeral Python one-shot for Hat Stack review runs
# Builds a minimal image that runs hats_runner.py or hats_task_runner.py,
# outputs JSON to stdout, and exits.

# Stage 1: Install dependencies
FROM python:3.12-slim AS builder

WORKDIR /build
COPY scripts/requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# Stage 2: Runtime image
FROM python:3.12-slim

LABEL org.opencontainers.image.title="Hat Stack Pipeline"
LABEL org.opencontainers.image.description="Ephemeral Hat Stack review runner — spins up, reviews, exits"
LABEL org.opencontainers.image.source="https://github.com/Grumpified-OGGVCT/hat_stack"

# Copy installed packages from builder
COPY --from=builder /install /usr/local

WORKDIR /app

# Copy scripts
COPY scripts/ /app/scripts/

# Default Ollama local URL — Docker Desktop can reach host via host.docker.internal
ENV OLLAMA_LOCAL_URL="http://host.docker.internal:11434"
ENV OLLAMA_CLOUD_URL="https://ollama.com"

# Default entrypoint: review runner
# Override with: docker run ... python scripts/hats_task_runner.py ...
ENTRYPOINT ["python", "scripts/hats_runner.py"]
CMD ["--help"]